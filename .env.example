# Скопируйте в .env и подправьте под себя:  cp .env.example .env
#
# Вариант 1 — бесплатно, локальная Ollama (рекомендуется):
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:4b
LLM_MODEL_FAST=qwen3:4b

# Вариант 2 — облако (OpenAI или любой OpenAI-совместимый: Groq, OpenRouter…):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_FAST=gpt-4o-nano

# Вариант 3 — совсем без LLM (деградированный режим, всё равно рабочий):
# LLM_API_KEY=

# Кэш ответов LLM: 1 — включён (по умолчанию), 0 — выключить
PORA_CACHE_ENABLED=1

# Скопируйте в .env и подправьте под себя:  cp .env.example .env
#
# Парсинг рецептов идёт в три ступени, LLM — последняя:
#   1. JSON-LD (schema.org)      — бесплатно, мгновенно
#   2. Python-парсер             — бесплатно, мгновенно (микроразметка / CSS / заголовок)
#   3. LLM                       — только если первые две ничего не нашли
# Поэтому на большинстве сайтов LLM вообще не вызывается, и дешёвого
# облачного ключа хватает надолго.

# --------------------------------------------------------------------------
# Вариант 1 — DeepSeek (рекомендуется: дёшево, OpenAI-совместимо, знает русский)
# Ключ: https://platform.deepseek.com → API keys
# --------------------------------------------------------------------------
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=deepseek-chat
LLM_MODEL_FAST=deepseek-chat

# --------------------------------------------------------------------------
# Вариант 2 — другие дешёвые OpenAI-совместимые провайдеры
# --------------------------------------------------------------------------
# Groq (есть бесплатный тариф):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter (есть модели с суффиксом :free):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=deepseek/deepseek-chat
#
# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_FAST=gpt-4o-mini

# --------------------------------------------------------------------------
# Вариант 3 — локальная Ollama (бесплатно, без интернета)
# ВАЖНО: берите instruct-модель, НЕ reasoning. qwen3 «размышляет» минутами и
# не годится для извлечения JSON — подойдёт qwen2.5 / llama3.1 / mistral.
# --------------------------------------------------------------------------
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:3b
# LLM_MODEL_FAST=qwen2.5:3b

# --------------------------------------------------------------------------
# Вариант 4 — совсем без LLM (деградированный режим, всё равно рабочий)
# Работают: все ML-эндпоинты, RU/EN категоризация, JSON-LD и Python-парсер.
# --------------------------------------------------------------------------
# LLM_API_KEY=

# Кэш ответов LLM: 1 — включён (по умолчанию), 0 — выключить
PORA_CACHE_ENABLED=1
